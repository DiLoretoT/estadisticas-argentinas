# Docker/Postgres
POSTGRES_DB=estadisticapp
POSTGRES_USER=estadisticapp
POSTGRES_PASSWORD=estadisticapp
POSTGRES_PORT=5432
PG_TIMEZONE=America/Argentina/Buenos_Aires

# ETL DB connection (psycopg)
PGHOST=localhost
PGPORT=5432
PGDATABASE=estadisticapp
PGUSER=estadisticapp
PGPASSWORD=estadisticapp
# Fallback para devcontainer sin Docker CLI (DB levantada en host/WSL)
# Se prueban hosts separados por coma, en este orden.
PGHOST_FALLBACK=host.docker.internal,gateway.docker.internal,172.17.0.1

# ETL behavior
ETL_EXPORT_JSON=1
ALLOW_INSECURE_SSL=0
